{
  "name": "vibe-sender",
  "productName": "Mentor Vault",
  "description": "Local teacher and mentor records database.",
  "author": "Luofaiz",
  "private": true,
  "version": "0.2.45",
  "type": "module",
  "main": "electron/main.mjs",
  "updateManifestUrl": "https://github.com/Luofaiz/mentor-vault/releases/latest/download/latest.json",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:desktop": "electron .",
    "dev:desktop:test": "powershell -ExecutionPolicy Bypass -File .\\scripts\\start-desktop-dev.ps1",
    "build": "vite build",
    "build:web": "vite build",
    "build:desktop:installer": "npm run build && electron-builder --win nsis --x64",
    "build:desktop:portable": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-electron-portable.ps1",
    "desktop": "electron .",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^35.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.luofaiz.mentorvault",
    "productName": "Mentor Vault",
    "directories": {
      "output": "release/installer"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/electron-updater/node_modules/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/sax/**/*"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/Luofaiz/mentor-vault/releases/download/v${version}/"
      }
    ],
    "asar": true,
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "afterPack": "scripts/after-pack-slim.cjs",
    "extraMetadata": {
      "updateManifestUrl": "https://github.com/Luofaiz/mentor-vault/releases/latest/download/latest.json"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MentorVaultSetup.${ext}"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mentor Vault",
      "deleteAppDataOnUninstall": false
    }
  }
}
